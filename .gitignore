# Terraform state — never commit state files
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable files may contain secrets
*.tfvars
*.tfvars.json

# Crash log
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
